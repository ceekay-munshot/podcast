# Munshot — local environment. Copy to `.env` (gitignored) and fill in one key.
#
# AI summaries are generated by /api/summary. Provide EITHER an OpenAI key OR an
# Anthropic key — whichever is set is auto-detected and used.

# OpenAI — https://platform.openai.com/api-keys (starts with "sk-")
OPENAI_API_KEY=

# Anthropic — https://console.anthropic.com/settings/keys (starts with "sk-ant-")
# ANTHROPIC_API_KEY=

# Optional model override. Defaults: OpenAI → gpt-4o-mini, Anthropic → claude-opus-4-8
# SUMMARY_MODEL=gpt-4o-mini
