# Munshot — local environment. Copy to `.env` (gitignored) and fill in.
#
# SUMMARIES — /api/summary needs EITHER an OpenAI key OR an Anthropic key
# (whichever is set is auto-detected and used).

# OpenAI — https://platform.openai.com/api-keys (starts with "sk-")
OPENAI_API_KEY=

# Anthropic — https://console.anthropic.com/settings/keys (starts with "sk-ant-")
# ANTHROPIC_API_KEY=

# Optional model override. Defaults: OpenAI → gpt-4o-mini, Anthropic → claude-opus-4-8
# SUMMARY_MODEL=gpt-4o-mini

# TRANSCRIPTION (optional) — used only for shows WITHOUT a transcript in their feed.
# Provider chain: feed transcript (free) → WHISPER_API_KEY (paid primary) → GROQ_API_KEY (free-tier backup)

# Groq free-tier Whisper — https://console.groq.com/keys (starts with "gsk_")
GROQ_API_KEY=

# Paid transcription primary (Deepgram / AssemblyAI / OpenAI Whisper) — wired when provided
# WHISPER_API_KEY=
